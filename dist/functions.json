                },
                {
                    "description": "Sort field with optional \"-\" prefix for desc (e.g. \"-market_cap\").",
                    "name": "orderBy",
                    "optional": true,
                    "type": "string"
                },
                {
                    "description": "Max results (default 50, max 200).",
